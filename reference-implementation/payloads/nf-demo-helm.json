{
  "deployment_id": "deploy-helm-001",
  "helix_id": "HELIX-HELM-001",
  "action": "deploy",
  "environment": "dev",
  "nf": "nf-demo",
  "is_bootstrap": true,
  "defaults": {
    "gitops_repo": "http://gitea-http.gitea.svc:3000/gitea_admin/nf-demo-gitops.git",
    "gitops_branch": "main",
    "helm_registry": "http://host.docker.internal:8081/repository/helm-hosted/",
    "argocd_project": "default"
  },
  "deployment_order": [
    {
      "component": "platform",
      "batch": 1
    },
    {
      "component": "simulator",
      "batch": 2
    },
    {
      "component": "collector",
      "batch": 3
    },
    {
      "component": "store",
      "batch": 3
    },
    {
      "component": "dashboard",
      "batch": 4
    },
    {
      "component": "gateway",
      "batch": 5
    }
  ],
  "components": {
    "platform": {
      "display_name": "NF Platform",
      "deployment_config": {
        "manual_approval": true,
        "approval_message": "Platform deployed. Verify config + server healthy.",
        "auto_rollback": false,
        "sync_policy": "manual",
        "sync_timeout": "180s"
      },
      "depends_on": [],
      "charts": {
        "nf-config": {
          "display_name": "Config Server",
          "chart_name": "nf-config",
          "chart_version": "1.0.0",
          "type": "helm",
          "deploy_order": 1,
          "sync_wave": "-5",
          "namespace": "nf-platform",
          "values_path": "platform/config",
          "values": {
            "replicaCount": 1,
            "version": "1.0.0",
            "config": {
              "networkFunction": "demo-5g",
              "environment": "dev",
              "features": {
                "monitoring": true,
                "alerting": false
              }
            }
          }
        },
        "nf-server": {
          "display_name": "NF Server",
          "chart_name": "nf-server",
          "chart_version": "2.1.0",
          "type": "helm",
          "deploy_order": 2,
          "sync_wave": "-4",
          "namespace": "nf-platform",
          "values_path": "platform/server",
          "depends_on": [
            "nf-config"
          ],
          "values": {
            "replicaCount": 2,
            "version": "1.0.0",
            "image": {
              "repository": "python",
              "tag": "3.12-alpine"
            },
            "service": {
              "port": 8000
            },
            "resources": {
              "requests": {
                "cpu": "50m",
                "memory": "64Mi"
              },
              "limits": {
                "cpu": "200m",
                "memory": "128Mi"
              }
            },
            "strategy": "rolling",
            "canary": {
              "steps": [
                {
                  "weight": 20,
                  "pause": -1
                },
                {
                  "weight": 50,
                  "pause": -1
                },
                {
                  "weight": 100,
                  "pause": 0
                }
              ]
            }
          }
        }
      }
    },
    "simulator": {
      "display_name": "Traffic Simulator",
      "deployment_config": {
        "manual_approval": false,
        "auto_rollback": true,
        "sync_policy": "manual",
        "sync_timeout": "120s"
      },
      "depends_on": [
        "platform"
      ],
      "charts": {
        "nf-simulator": {
          "display_name": "Traffic Simulator",
          "chart_name": "nf-simulator",
          "chart_version": "1.0.0",
          "type": "helm",
          "deploy_order": 3,
          "sync_wave": "-3",
          "namespace": "nf-simulator",
          "values_path": "simulator",
          "values": {
            "replicaCount": 1,
            "burstSize": 20,
            "quietPeriod": 10,
            "targetServer": "nf-server.nf-platform.svc.cluster.local:8000"
          }
        }
      }
    },
    "collector": {
      "display_name": "Metrics Collector",
      "deployment_config": {
        "manual_approval": false,
        "auto_rollback": true,
        "sync_policy": "manual",
        "sync_timeout": "180s"
      },
      "depends_on": [
        "platform"
      ],
      "charts": {
        "prometheus": {
          "display_name": "Prometheus",
          "chart_name": "nf-collector",
          "chart_version": "1.0.0",
          "type": "helm",
          "deploy_order": 4,
          "sync_wave": "-2",
          "namespace": "nf-collector",
          "values_path": "collector",
          "values": {
            "replicaCount": 1,
            "retention": "12h",
            "scrapeTargets": [
              {
                "jobName": "nf-server",
                "target": "nf-server.nf-platform.svc.cluster.local:8000",
                "interval": "10s"
              }
            ]
          }
        }
      }
    },
    "store": {
      "display_name": "Data Store",
      "deployment_config": {
        "manual_approval": false,
        "auto_rollback": true,
        "sync_policy": "manual",
        "sync_timeout": "120s"
      },
      "depends_on": [
        "platform"
      ],
      "charts": {
        "redis": {
          "display_name": "Redis",
          "chart_name": "nf-store",
          "chart_version": "1.0.0",
          "type": "multi_instance",
          "deploy_order": 5,
          "sync_wave": "-2",
          "values_path": "store",
          "instances": {
            "cache": {
              "namespace": "nf-store",
              "values_path": "store/cache",
              "values": {
                "instanceName": "cache",
                "replicaCount": 1,
                "maxMemory": "64mb"
              }
            },
            "sessions": {
              "namespace": "nf-store",
              "values_path": "store/sessions",
              "values": {
                "instanceName": "sessions",
                "replicaCount": 1,
                "maxMemory": "64mb"
              }
            },
            "events": {
              "namespace": "nf-store",
              "values_path": "store/events",
              "values": {
                "instanceName": "events",
                "replicaCount": 1,
                "maxMemory": "64mb"
              }
            }
          }
        }
      }
    },
    "dashboard": {
      "display_name": "Dashboard",
      "deployment_config": {
        "manual_approval": true,
        "approval_message": "Metrics pipeline live. Verify Grafana shows data.",
        "auto_rollback": false,
        "sync_policy": "manual",
        "sync_timeout": "180s"
      },
      "depends_on": [
        "collector"
      ],
      "charts": {
        "grafana": {
          "display_name": "Grafana",
          "chart_name": "nf-dashboard",
          "chart_version": "1.0.0",
          "type": "helm",
          "deploy_order": 6,
          "sync_wave": "-1",
          "namespace": "nf-dashboard",
          "values_path": "dashboard",
          "values": {
            "replicaCount": 1,
            "admin": {
              "user": "admin",
              "password": "admin123"
            },
            "prometheus": {
              "url": "http://prometheus.nf-collector.svc.cluster.local:9090"
            }
          }
        }
      }
    },
    "gateway": {
      "display_name": "API Gateway",
      "deployment_config": {
        "manual_approval": false,
        "auto_rollback": true,
        "sync_policy": "manual",
        "sync_timeout": "120s"
      },
      "depends_on": [
        "dashboard"
      ],
      "charts": {
        "nf-gateway": {
          "display_name": "Gateway + Routing",
          "chart_name": "nf-gateway",
          "chart_version": "1.9.2",
          "type": "helm",
          "deploy_order": 7,
          "sync_wave": "0",
          "namespace": "nf-gateway",
          "values_path": "gateway",
          "values": {
            "replicaCount": 1,
            "version": "1.0.0",
            "upstreams": {
              "server": "nf-server.nf-platform.svc.cluster.local:8000",
              "config": "nf-config.nf-platform.svc.cluster.local:80",
              "grafana": "grafana.nf-dashboard.svc.cluster.local:3000",
              "prometheus": "prometheus.nf-collector.svc.cluster.local:9090"
            },
            "simulator": {
              "burstSize": 20,
              "quietPeriod": 10
            }
          }
        }
      }
    }
  }
}