{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Deployment API Response",
  "description": "Shape returned by GET /api/v1/deployments/{deployment_id}. Contains the RESOLVED payload (all placeholders substituted, user_editable/non_editable merged into flat values). This does NOT validate the raw app-config template — see App-Config-Data-Model.md for the template schema.",
  "type": "object",
  "required": ["deployment_id", "helix_id", "action", "environment", "nf", "status", "created_at", "payload", "runtime"],
  "additionalProperties": false,
  "properties": {
    "deployment_id": { "type": "string", "description": "Unique deployment identifier" },
    "helix_id":      { "type": "string", "description": "Helix ticket that triggered this deployment" },
    "action":        { "type": "string", "enum": ["deploy", "rollback"], "description": "Deployment action type" },
    "environment":   { "type": "string", "description": "Target environment (e.g. prod, pre-prod, rnd)" },
    "nf":            { "type": "string", "description": "Network function identifier (e.g. ims)" },
    "status":        { "$ref": "#/$defs/deployment_status" },
    "is_bootstrap":  { "type": "boolean", "default": false, "description": "True if this is the first deployment (app-of-apps creation)" },
    "created_at":    { "type": "string", "format": "date-time" },
    "completed_at":  { "type": ["string", "null"], "format": "date-time" },
    "payload":       { "$ref": "#/$defs/resolved_payload" },
    "runtime":       { "$ref": "#/$defs/runtime" }
  },

  "$defs": {

    "deployment_status": {
      "type": "string",
      "enum": ["pending", "in_progress", "pending_approval", "success", "failed", "rolled_back", "cancelled"],
      "description": "Overall deployment status. pending_approval indicates the orchestrator is paused at an approval gate awaiting operator action via PUT /approve"
    },

    "resolved_payload": {
      "type": "object",
      "description": "Resolved app-config: all placeholders replaced, user_editable + non_editable merged into values.",
      "required": ["metadata", "defaults", "deployment_order", "components"],
      "additionalProperties": false,
      "properties": {
        "metadata": {
          "type": "object",
          "properties": {
            "nf":               { "type": "string" },
            "vendor":           { "type": "string" },
            "description":      { "type": "string" },
            "total_components":  { "type": "integer" },
            "total_charts":      { "type": "integer" },
            "platform":         { "type": "string" },
            "schema_version":   { "type": "string" }
          }
        },
        "defaults": {
          "type": "object",
          "required": ["gitops_repo", "helm_registry", "argocd_project"],
          "properties": {
            "helm_registry":    { "type": "string", "description": "Nexus Helm repository URL" },
            "image_registry":   { "type": "string" },
            "pull_secret":      { "type": "string" },
            "storage_class":    { "type": "string" },
            "service_account_prefix": { "type": "string" },
            "node_selector":    { "type": "object" },
            "gitops_repo":      { "type": "string", "description": "GitLab repository URL for the GitOps repo" },
            "gitops_branch":    { "type": "string", "description": "Branch to commit to (default: main)" },
            "argocd_project":   { "type": "string", "description": "ArgoCD project name" },
            "argocd_app_of_apps": { "type": "string" }
          }
        },
        "deployment_order": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["component", "batch"],
            "properties": {
              "component": { "type": "string", "description": "Component key matching a key in components object" },
              "batch":     { "type": "integer", "description": "Batch number (1-based). Lower batches deploy first. Same batch = parallel" }
            }
          }
        },
        "components": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/resolved_component" }
        }
      }
    },

    "resolved_component": {
      "type": "object",
      "required": ["display_name", "namespace", "deployment_config", "charts"],
      "properties": {
        "display_name":      { "type": "string" },
        "namespace":         { "type": "string" },
        "deployment_config": {
          "type": "object",
          "properties": {
            "manual_approval":  { "type": "boolean" },
            "approval_message": { "type": "string" },
            "health_check":     { "type": "object" },
            "auto_rollback":    { "type": "boolean" },
            "sync_timeout":     { "type": "string" },
            "sync_policy":      { "type": "string", "enum": ["manual", "auto", "auto_self_heal"], "description": "ArgoCD sync policy for this component" },
            "strategy":         { "type": "string", "enum": ["rolling", "canary", "blueGreen"], "description": "Deployment strategy. rolling=current, canary/blueGreen=future (Argo Rollouts)" }
          }
        },
        "depends_on": { "type": "array", "items": { "type": "string" } },
        "charts": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/resolved_chart" }
        }
      }
    },

    "resolved_chart": {
      "type": "object",
      "description": "Chart with resolved values. For type=helm, values contains the merged Helm values. For type=multi_instance, instances contains per-instance values instead.",
      "required": ["chart_name", "chart_version", "deploy_order", "sync_wave", "type", "namespace", "values_path"],
      "properties": {
        "chart_name":    { "type": "string", "description": "Helm chart name in Nexus" },
        "chart_version": { "type": "string", "description": "Chart version — becomes targetRevision in ArgoCD Application" },
        "deploy_order":  { "type": "integer", "description": "Global ordering across all charts (unique)" },
        "sync_wave":     { "type": "string", "description": "ArgoCD sync-wave annotation value. String because K8s annotations are strings. Numeric value controls ordering (lower = earlier)" },
        "type":          { "type": "string", "enum": ["helm", "multi_instance"], "description": "helm=standard single chart with values. multi_instance=same chart deployed N times with per-instance values in instances object" },
        "chart_pattern": { "type": "string", "enum": ["umbrella", "standalone", "multi_instance"], "description": "Packaging pattern from vendor: umbrella (sub-charts), standalone, multi_instance" },
        "namespace":     { "type": "string", "description": "Authoritative target K8s namespace — used in ArgoCD Application destination.namespace" },
        "values_path":   { "type": "string", "description": "Path in GitOps repo: environments/{env}/values/{values_path}/values.yaml" },
        "display_name":  { "type": "string" },
        "depends_on":    { "type": "array", "items": { "type": "string" }, "description": "Intra-component chart ordering (e.g., cmsplatform before cmsnfv)" },
        "values":        { "type": "object", "description": "Merged and resolved Helm values for type=helm. Not present for type=multi_instance (use instances instead)" },
        "instances": {
          "type": "object",
          "description": "For type=multi_instance only. Each key is an instance name. Each instance becomes a separate ArgoCD Application.",
          "additionalProperties": {
            "type": "object",
            "required": ["namespace", "values_path", "values"],
            "properties": {
              "suffix":      { "type": "string", "description": "Instance suffix for naming (e.g., 'mtas' → app name becomes '{chart}-mtas')" },
              "namespace":   { "type": "string", "description": "Target K8s namespace for this instance" },
              "values_path": { "type": "string", "description": "GitOps path for this instance's values.yaml" },
              "values":      { "type": "object", "description": "Fully resolved values for this instance" }
            }
          }
        }
      },
      "if": { "properties": { "type": { "const": "helm" } } },
      "then": { "required": ["values"] },
      "else": { "required": ["instances"] }
    },

    "runtime": {
      "type": "object",
      "description": "Deployment progress. Updated by the orchestrator at each stage, read by frontend via GET /api/v1/deployments/{id}.",
      "required": ["deployed", "component_results"],
      "additionalProperties": false,
      "properties": {
        "deployed": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Component keys that have been successfully deployed"
        },
        "current": {
          "type": ["string", "null"],
          "description": "Component key currently being deployed"
        },
        "pending_approval": {
          "type": "boolean",
          "default": false,
          "description": "True when Hub is waiting for manual approval to proceed"
        },
        "component_results": {
          "type": "object",
          "description": "Map of component_key -> deployment result",
          "additionalProperties": { "$ref": "#/$defs/component_result" }
        }
      }
    },

    "component_result": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": { "$ref": "#/$defs/chart_status", "description": "Derived from chart statuses: healthy only when all charts healthy" },
        "commit_sha": { "type": ["string", "null"], "description": "Git commit SHA for this component's GitOps commit" },
        "version": { "type": ["string", "null"], "description": "Deployed version of the component (from payload values)" },
        "deployed_at": { "type": ["string", "null"], "format": "date-time" },
        "charts": {
          "type": "object",
          "description": "Map of chart_key (or instance_key for multi_instance) -> chart result",
          "additionalProperties": { "$ref": "#/$defs/chart_result" }
        }
      }
    },

    "chart_result": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status":        { "$ref": "#/$defs/chart_status" },
        "synced_at":     { "type": ["string", "null"], "format": "date-time", "description": "When ArgoCD sync completed" },
        "health_report": {
          "type": ["object", "null"],
          "description": "Health check details reported by pipeline",
          "properties": {
            "pods_ready":               { "type": "string", "description": "e.g. 6/6" },
            "services_with_endpoints":  { "type": "string", "description": "e.g. 3/3" },
            "version_match":            { "type": "boolean" }
          }
        },
        "errors": {
          "type": "array",
          "description": "Error details from ArgoCD resource-tree if status is unhealthy",
          "items": {
            "type": "object",
            "properties": {
              "kind":    { "type": "string", "description": "K8s resource kind (e.g., Pod, Service, PVC)" },
              "name":    { "type": "string", "description": "Resource name" },
              "message": { "type": "string", "description": "Error message from ArgoCD" }
            }
          }
        }
      }
    },

    "chart_status": {
      "type": "string",
      "enum": ["pending", "in_progress", "synced", "healthy", "unhealthy", "rolled_back", "skipped"],
      "description": "Lifecycle status of a chart deployment"
    }
  }
}
